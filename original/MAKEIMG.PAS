UNIT MAKEIMG;
INTERFACE

PROCEDURE WRITEIMG(FN: STRING; X1,Y1,X2,Y2: INTEGER);
PROCEDURE READIMG2BUF(FN: STRING; VAR BUF: POINTER; VAR SIZE: WORD);
PROCEDURE SHOWIMG(FN: STRING; X,Y: INTEGER; BITBLT: WORD);

IMPLEMENTATION

USES GRAPH;

PROCEDURE WRITEIMG(FN: STRING; X1,Y1,X2,Y2: INTEGER);
VAR
  F: FILE;
  SIZE: WORD;
  P: POINTER;
BEGIN
  ASSIGN(F, FN+'.IMG');
  REWRITE(F,1);
  SIZE := IMAGESIZE(X1,Y1,X2,Y2);
  GETMEM(P, SIZE);
  GETIMAGE(X1,Y1,X2,Y2, P^);
  BLOCKWRITE(F, P^, SIZE);
  CLOSE(F);
  FREEMEM(P, SIZE);
END;

PROCEDURE READIMG2BUF(FN: STRING; VAR BUF: POINTER; VAR SIZE: WORD);
VAR
  F: FILE;
BEGIN
  ASSIGN(F, FN+'.IMG');
  RESET(F,1);
  SIZE := FILESIZE(F);
  GETMEM(BUF, SIZE);
  BLOCKREAD(F,BUF^,SIZE);
  CLOSE(F);
END;

PROCEDURE SHOWIMG(FN: STRING; X,Y: INTEGER; BITBLT: WORD);
VAR
  SIZE: WORD;
  P: POINTER;
BEGIN
  READIMG2BUF(FN,P,SIZE);
  PUTIMAGE(X,Y,P^,BITBLT);
  FREEMEM(P, SIZE);
END;

END.