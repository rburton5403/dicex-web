UNIT GRAPHPCX;

INTERFACE

TYPE
  PCXHEADER = RECORD
    FLAG: BYTE;
    VERSION: BYTE;
    ENCODING: BYTE;
    BPPIX: BYTE;          { BITS PER PIXEL }
    XUL,
    YUL,
    XLR,
    YLR: WORD;
    HDPI: WORD;
    VDPI: WORD;
    PAL16: ARRAY[1..16,1..3] OF BYTE;
    RESERVED: BYTE;
    NPLANES: BYTE;
    BPLINE: WORD;                           { BYTES PER LINE }
    PALINFO: WORD;
    HSCRN,
    VSCRN: WORD;
    FILLER: ARRAY[1..54] OF BYTE;
  END;

FUNCTION SHOWPCX(FN: STRING; X,Y: WORD): INTEGER;

IMPLEMENTATION

USES
  DOS, GRAPH,
  STRINGS;

{=========================================}
{ DISPLAY A PCX FILE TO THE GRAPHICS PAGE }
{=========================================}
FUNCTION SHOWPCX(FN: STRING; X,Y: WORD): INTEGER;
VAR
  F: FILE;              { PCX FILE }
  I: INTEGER;           { MISC INT }
  PH: PCXHEADER;        { PCX HEADER }
  HORZSIZE,             { PIXEL DIM OF DISPLAYED IMAGE - HORZ }
  VERTSIZE,             { VERT }
  BUFSIZE: WORD;        { BYTES REQ TO BUFFER ONE COMPLETE SCAN LINE }
  SCANBUF: POINTER;     { BUFFER TO DECODE INTO }
  BUFPTR: WORD;         { POINTER INTO BUFFER, NEXT FREE POS }
  CURRLINE: WORD;       { CURRENT SCAN LINE WORKING ON }
  READBUF: ARRAY[1..512] OF BYTE;
  BYTESREAD: WORD;
BEGIN
  SHOWPCX := 0;

  { OPEN PCX FILE }
  {$I-}
  ASSIGN(F, FN);
  RESET(F, 1);
  {$I+}
  I := IORESULT;
  IF I <> 0 THEN
  BEGIN
    SHOWPCX := I;
    EXIT;
  END;

  { READ HEADER }
  BLOCKREAD(F, PH, 128);

  { DECODE }

  HORZSIZE := PH.XLR-PH.XUL+1;
  VERTSIZE := PH.YLR-PH.YUL+1;
  BUFSIZE := PH.NPLANES*PH.BPLINE;  { BUF SIZE FOR SCAN LINE, ALL PLANES }

  CURRLINE := 1;
  SCANBUF := NIL;
  BUFPTR := 1;
  READBUFPTR := 1;

  WHILE (CURRLINE <= PH.VDPI) AND  DO
  BEGIN
    { READ FROM PCX FILE ENCODED DATA }
    IF READBUFPTR > BYTESREAD THEN
    BEGIN
      BLOCKREAD(F, READBUF, SIZEOF(READBUF), BYTESREAD);
      READBUFPTR := 1;
    END;

    { DECODE UNTIL SCANLINE BUFFER FILLED }
    IF SCANBUF = NIL THEN          { CREATE NEW BUF IF NEEDED }
    BEGIN
      GETMEM(SCANBUF, BUFSIZE);
      BUFPTR := 1;
    END;

    IF READBUFPTR <= BYTESREAD THEN
    BEGIN
      READBUF[READBUFPTR]
    END;




    FREEMEM(SCANBUF);

    INC(CURRLINE);
  END;

END;

END.
