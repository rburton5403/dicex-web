UNIT PLAYAREA;
INTERFACE

CONST
  FIELDMAXX = 9;
  FIELDMAXY = 13;

  GRAVITYAT: WORD = 30;

TYPE
  TBA = ARRAY[1..MAXINT] OF BYTE;

VAR
  DICEBITMAP: ARRAY[0..6] OF POINTER;
  DIESIZE: WORD;
  PLAYFIELD: ARRAY[1..FIELDMAXX, 1..FIELDMAXY] OF BYTE;
  ELIMGRID: ARRAY[1..FIELDMAXX, 1..FIELDMAXY] OF BOOLEAN;
  LASTSSEC: WORD;
  GRAVITYCOUNT: WORD;

PROCEDURE READDICE;
PROCEDURE FREEDICE;
PROCEDURE NEWPLAYAREA;
PROCEDURE FILLWITHDICE(HOWMANY: INTEGER);
PROCEDURE PUTDIE(X,Y: INTEGER; DIE: BYTE);
PROCEDURE DRAWDIEAT(X,Y: INTEGER; DIE: BYTE);
PROCEDURE FILLFIELD(DIE: BYTE);
PROCEDURE DOGRAVITY(VAR ANYFALL: BOOLEAN);
PROCEDURE CHECKGRAVITY(VAR DIDGRAVITY, ANYFALL: BOOLEAN);
PROCEDURE STARTGRAVITY;
PROCEDURE CHECKELIM(VAR SUB69: INTEGER);
PROCEDURE ELIMLINE(VAR CHKPTR: POINTER; FIELDLEN: INTEGER; VAR WASCHANGE: BOOLEAN);

IMPLEMENTATION

USES GRAPH, CRT, STRINGS, TIME, NUMBERS,
     MAKEIMG, PALEFF;

{ READ THE DICE INTO MEMORY }
PROCEDURE READDICE;
VAR
  X: INTEGER;
BEGIN
  FOR X := 0 TO 6 DO
    READIMG2BUF(INTTOSTR(X)+'DIE', DICEBITMAP[X], DIESIZE);
END;

PROCEDURE FREEDICE;
VAR
  X: INTEGER;
BEGIN
  FOR X := 1 TO 6 DO
    FREEMEM(DICEBITMAP[X], DIESIZE);
END;

{ DRAW A NEW PLAY AREA AND INIT }
PROCEDURE NEWPLAYAREA;
VAR
  P: POINTER;
  SIZE: WORD;
  X,Y,
  C: INTEGER;
  OLDPAL: PALETTETYPE;
BEGIN
  { SET UP PLAY SCREEN }
  PALFADEOUT(OLDPAL, FALSE);
  SHOWIMG('LOGO', (640-375) DIV 2, 1, NORMALPUT);

  READIMG2BUF('BORDER', P, SIZE);

  FOR Y := 0 TO 12 DO
  BEGIN
    FOR X := 0 TO 1 DO
      PUTIMAGE( (640-(26*13)) DIV 2 +(26*X), (27*Y)+100, P^, NORMALPUT);
    FOR X := 0 TO 1 DO
      PUTIMAGE( (640-(26*13)) DIV 2 +(26*(X+11)), (27*Y)+100, P^, NORMALPUT);
  END;

  FOR X := -6 TO 17 DO
    PUTIMAGE( (640-(26*13)) DIV 2 +(26*X), (27*13)+100, P^, NORMALPUT);

  FILLFIELD(0);

  PALFADEIN(OLDPAL, TRUE);
  FREEMEM(P, SIZE);

{  FOR C := 1 TO 6 DO FILLFIELD(C);
  FILLFIELD(0);}
END;

PROCEDURE FILLWITHDICE(HOWMANY: INTEGER);
VAR
  X: INTEGER;
  WHICHDIE: INTEGER;
BEGIN
  FOR X := 1 TO HOWMANY DO
  BEGIN
    REPEAT
      WHICHDIE := RANDOM(7);
    UNTIL WHICHDIE IN [1..6];
    PUTIMAGE(RANDOM(640),RANDOM(480),DICEBITMAP[WHICHDIE]^, NORMALPUT);
  END;
END;

PROCEDURE PUTDIE(X,Y: INTEGER; DIE: BYTE);
BEGIN
  PLAYFIELD[X,Y] := DIE;
  DRAWDIEAT(X,Y,DIE);
END;

PROCEDURE DRAWDIEAT(X,Y: INTEGER; DIE: BYTE);
BEGIN
  PUTIMAGE( (640-(26*13)) DIV 2 +(26*(X+1)), (27*(Y-1))+100,
    DICEBITMAP[DIE]^, NORMALPUT);
END;

PROCEDURE FILLFIELD(DIE: BYTE);
VAR
  X,Y: INTEGER;
BEGIN
  FOR Y := 1 TO FIELDMAXY DO
    FOR X := 1 TO FIELDMAXX DO
    BEGIN
      PLAYFIELD[X,Y] := DIE;
      DRAWDIEAT(X,Y,DIE);
    END;
END;

PROCEDURE DOGRAVITY(VAR ANYFALL: BOOLEAN);
VAR
  X,Y: INTEGER;
BEGIN
  ANYFALL := FALSE;

  FOR Y := FIELDMAXY-1 DOWNTO 1 DO
    FOR X := 1 TO FIELDMAXX DO
    BEGIN
      { IF SPACE UNDERNEATH A DIE THEN MAKE IT FALL }
      IF (PLAYFIELD[X,Y] <> 0) AND (PLAYFIELD[X,Y+1] = 0) THEN
      BEGIN
        PUTDIE(X,Y+1, PLAYFIELD[X,Y]);
        PUTDIE(X,Y, 0);
        ANYFALL := TRUE;
      END;
    END;
END;

PROCEDURE CHECKGRAVITY(VAR DIDGRAVITY, ANYFALL: BOOLEAN);
VAR
  NOWS: WORD;
BEGIN
  NOWS := NOWSSEC;
  IF NOWS <> LASTSSEC THEN
  BEGIN
    IF NOWS < LASTSSEC THEN
      INC(GRAVITYCOUNT, (100-LASTSSEC)+NOWS)
    ELSE
      INC(GRAVITYCOUNT, NOWS-LASTSSEC);
  END;
  LASTSSEC := NOWS;

  IF GRAVITYCOUNT > GRAVITYAT THEN
  BEGIN
    GRAVITYCOUNT := 0;
    DOGRAVITY(ANYFALL);
    DIDGRAVITY := TRUE;
  END
  ELSE
    DIDGRAVITY := FALSE;
END;

PROCEDURE STARTGRAVITY;
BEGIN
  GRAVITYCOUNT := 0;
  LASTSSEC := NOWSSEC;
END;

{ SCAN THE GAME BOARD AND ELIMINATE ANY DICE THAT FORM A VALID COMBINATION }
PROCEDURE CHECKELIM(VAR SUB69: INTEGER);
VAR
  CHKPTR: POINTER;
  CHKLEN: INTEGER;
  X,Y: INTEGER;
  WASCHANGE: BOOLEAN;
BEGIN
  { CREATE ARRAY FOR READING EITHER HORZ OR VERT }
  CHKLEN := LARGEST(FIELDMAXX, FIELDMAXY);
  GETMEM(CHKPTR, CHKLEN);

  { FALSE ELIM GRID }
  FOR Y := 1 TO FIELDMAXY DO
    FOR X := 1 TO FIELDMAXX DO
      ELIMGRID[X,Y] := FALSE;

  SUB69 := 0;

  { FIRST CHECK HORZ }
  FOR Y := 1 TO FIELDMAXY DO
  BEGIN
    { READ IN CHK }
    FOR X := 1 TO CHKLEN DO
      IF X > FIELDMAXX THEN
        TBA(CHKPTR^)[X] := 0
      ELSE
        TBA(CHKPTR^)[X] := PLAYFIELD[X,Y];

    { DO ELIMINATION ON LINE }
    ELIMLINE(CHKPTR, FIELDMAXX, WASCHANGE);

    { REPLACE INTO PLAYFIELD }
    IF WASCHANGE THEN
    BEGIN
      FOR X := 1 TO CHKLEN DO
        IF X <= FIELDMAXX THEN
          IF TBA(CHKPTR^)[X] <> PLAYFIELD[X,Y] THEN ELIMGRID[X,Y] := TRUE;
      INC(SUB69);
    END;
  END;

  { CHECK VERT }
  FOR X := 1 TO FIELDMAXX DO
  BEGIN
    { READ IN CHK }
    FOR Y := 1 TO CHKLEN DO
      IF Y > FIELDMAXY THEN
        TBA(CHKPTR^)[Y] := 0
      ELSE
        TBA(CHKPTR^)[Y] := PLAYFIELD[X,Y];

    { DO ELIMINATION ON LINE }
    ELIMLINE(CHKPTR, FIELDMAXY, WASCHANGE);

    { REPLACE INTO PLAYFIELD }
    IF WASCHANGE THEN
    BEGIN
      FOR Y := 1 TO CHKLEN DO
        IF Y <= FIELDMAXY THEN
          IF TBA(CHKPTR^)[Y] <> PLAYFIELD[X,Y] THEN ELIMGRID[X,Y] := TRUE;
      INC(SUB69);
    END;
  END;

  FOR Y := 1 TO FIELDMAXY DO
    FOR X := 1 TO FIELDMAXX DO
      IF ELIMGRID[X,Y] THEN PUTDIE(X,Y,0);
END;

PROCEDURE ELIMLINE(VAR CHKPTR: POINTER; FIELDLEN: INTEGER; VAR WASCHANGE: BOOLEAN);
VAR
  GOT6, GOT9: BOOLEAN;
  STARTFROMZERO: INTEGER;
  START6, END9: LONGINT;
  C,X,L: INTEGER;
  TOTAL: INTEGER;
BEGIN
  WASCHANGE := FALSE;

  { SCAN FOR 6-9 }
  FOR C := 1 TO FIELDLEN DO
  BEGIN
    GOT6 := FALSE;
    GOT9 := FALSE;
    STARTFROMZERO := 0;
    START6 := 0;
    END9 := 0;
    TOTAL := 0;

    FOR X := C TO FIELDLEN DO
    BEGIN
      CASE TBA(CHKPTR^)[X] = 0 OF
        TRUE:
          BEGIN
            GOT6 := FALSE;
            GOT9 := FALSE;
            TOTAL := 0;
          END;

        FALSE:
          BEGIN
            IF TOTAL = 0 THEN STARTFROMZERO := X;

            INC(TOTAL, TBA(CHKPTR^)[X]);
            CASE TOTAL OF
              6:
                IF NOT GOT6 THEN
                BEGIN
                  GOT6 := TRUE;
                  IF GOT9 THEN
                    START6 := X
                  ELSE
                    START6 := STARTFROMZERO;
                  TOTAL := 0;
                END;
              9:
                IF NOT GOT9 THEN
                BEGIN
                  GOT9 := TRUE;
                  IF GOT6 THEN
                    END9 := X
                  ELSE
                    END9 := STARTFROMZERO;
                  TOTAL := 0;
                END;
            END;

            IF GOT6 AND GOT9 THEN
            BEGIN
              { MAKE START6 LESS THAN END9 }
              IF START6 > END9 THEN EXCHANGE(START6, END9);
              FOR L := START6 TO END9 DO
                TBA(CHKPTR^)[L] := 0;
              WASCHANGE := TRUE;
            END;
          END;
      END;
    END;
  END; {FOR C}
END;

END.