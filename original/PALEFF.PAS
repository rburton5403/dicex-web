{ PALETTE EFFECTS }

UNIT PALEFF;

INTERFACE

USES GRAPH, CRT;

CONST
  FADEDELAY = 50;

PROCEDURE PALFADEOUT(VAR SAVEPAL: PALETTETYPE; SLOW: BOOLEAN);
PROCEDURE PALFADEIN(PAL: PALETTETYPE; SLOW: BOOLEAN);

IMPLEMENTATION

{=============================================}
{ STORE OLD PALETTE AND FADE PALETTE TO BLACK }
{=============================================}
PROCEDURE PALFADEOUT(VAR SAVEPAL: PALETTETYPE; SLOW: BOOLEAN);
VAR
  X: INTEGER;
BEGIN
  GETPALETTE(SAVEPAL);
  FOR X := 0 TO 15 DO
  BEGIN
    SETPALETTE(X,0);
    IF SLOW THEN DELAY(FADEDELAY);
  END;
END;

{======================================}
{ FADE PALETTE IN USING PASSED PALETTE }
{======================================}
PROCEDURE PALFADEIN(PAL: PALETTETYPE; SLOW: BOOLEAN);
VAR
  X: INTEGER;
BEGIN
  FOR X := 0 TO 15 DO
  BEGIN
    SETPALETTE(X,PAL.COLORS[X]);
    IF SLOW THEN DELAY(FADEDELAY);
  END;
END;

END.