{ RODNEY'S GRAPHICS FORMAT }

UNIT RGFSUPP;
INTERFACE

TYPE
  GFIRECORD = RECORD
    SIZEX,
    SIZEY: INTEGER;
  END;

PROCEDURE SHOWRGF(FN: STRING; XS,YS: INTEGER);
PROCEDURE CLIPRAW2RGF(FN: STRING; X1,Y1,X2,Y2: INTEGER);

IMPLEMENTATION

USES GRAPH, CRT;

PROCEDURE SHOWRGF(FN: STRING; XS,YS: INTEGER);
TYPE
  PTYPE = ARRAY[1..32768] OF BYTE;
VAR
  RGFFILE: FILE;
  GFIFILE: FILE OF GFIRECORD;
  GFIREC: GFIRECORD;
  BREAD: WORD;
  C: WORD;
  P: POINTER;
  XO,YO: INTEGER;
BEGIN
  {$I-}
  ASSIGN(RGFFILE, FN+'.RGF'); RESET(RGFFILE,1);
  ASSIGN(GFIFILE, FN+'.GFI'); RESET(GFIFILE);
  READ(GFIFILE, GFIREC);
  CLOSE(GFIFILE);
  {$I+}
  IF IORESULT <> 0 THEN EXIT;

  XO := 0;
  YO := 0;
  GETMEM(P, 32768);

  WHILE NOT EOF(RGFFILE) DO
  BEGIN
    BLOCKREAD(RGFFILE,P^,32768,BREAD);
    FOR C := 1 TO BREAD DO
    BEGIN
      IF XO+1 > GFIREC.SIZEX THEN
      BEGIN
        XO := 0;
        INC(YO);
      END;

      IF (XO+XS <= 640) AND (YO+YS <= 480) THEN
      BEGIN
        IF PTYPE(P^)[C] > 15 THEN
          WRITE;

        { REMAP COLORS }
        CASE PTYPE(P^)[C] OF
          12: PTYPE(P^)[C] := 9;
          8: PTYPE(P^)[C] := 7;
          7: PTYPE(P^)[C] := 8;
          9: PTYPE(P^)[C] := 12;
          1: PTYPE(P^)[C] := 4;
          11: PTYPE(P^)[C] := 14;
          3: PTYPE(P^)[C] := 6;
          14: PTYPE(P^)[C] := 11;
          6: PTYPE(P^)[C] := 3;
          12: PTYPE(P^)[C] := 9;
          4: PTYPE(P^)[C] := 1;
        END;

        PUTPIXEL(XO+XS,YO+YS,PTYPE(P^)[C]);
      END;

      INC(XO);
    END;
  END;

  FREEMEM(P, 32768);
  CLOSE(RGFFILE);
END;

{ READ A RAW FILE AND CLIP IT TO A RGF FILE }
PROCEDURE CLIPRAW2RGF(FN: STRING; X1,Y1,X2,Y2: INTEGER);
VAR
  RAWFILE,
  RGFFILE: FILE;
  GFIFILE: FILE OF GFIRECORD;
  GFIREC: GFIRECORD;
  P: ARRAY[1..640] OF BYTE;
  X,Y: INTEGER;
BEGIN
  ASSIGN(RAWFILE, FN+'.RAW'); RESET(RAWFILE,1);
  ASSIGN(RGFFILE, FN+'.RGF'); REWRITE(RGFFILE,1);
  ASSIGN(GFIFILE, FN+'.GFI'); REWRITE(GFIFILE);
  GFIREC.SIZEX := X2-X1+1;
  GFIREC.SIZEY := Y2-Y1+1;
  WRITE(GFIFILE, GFIREC);
  CLOSE(GFIFILE);

  Y := 1;
  REPEAT
    BLOCKREAD(RAWFILE, P, 640);
    IF (Y >= Y1) AND (Y <= Y2) THEN
      FOR X := 1 TO 640 DO
        IF (X >= X1) AND (X <= X2) THEN
          BLOCKWRITE(RGFFILE, P[X], 1);
    INC(Y);
  UNTIL Y > 480;

  CLOSE(RAWFILE);
  CLOSE(RGFFILE);
END;

END.
